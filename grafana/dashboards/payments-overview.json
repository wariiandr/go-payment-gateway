        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(payment_processing_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(payment_processing_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
